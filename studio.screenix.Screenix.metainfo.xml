<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>studio.screenix.Screenix</id>
  <name>Screenix</name>
  <summary>Professional screen recorder with smooth zoom effects</summary>
  <developer id="studio.screenix">
    <name>Screenix</name>
  </developer>
  <metadata_license>MIT</metadata_license>
  <project_license>LicenseRef-proprietary</project_license>

  <description>
    <p>
      Screenix is a professional screen recorder for Linux with real-time
      GPU-accelerated zoom effects, click indicators, and hardware-accelerated
      export. Works on both X11 and Wayland (via XDG desktop portal and PipeWire).
    </p>
    <ul>
      <li>Real-time zoom with smooth cursor-following animation</li>
      <li>Click effect overlays</li>
      <li>GPU-accelerated export (VAAPI, NVENC)</li>
      <li>Wayland support via XDG ScreenCast portal and PipeWire</li>
      <li>GNOME, KDE Plasma, and wlroots compositor support</li>
    </ul>
  </description>

  <launchable type="desktop-id">studio.screenix.Screenix.desktop</launchable>

  <url type="homepage">https://screenix.studio</url>

  <provides>
    <binary>screenix-gui</binary>
  </provides>

  <screenshots>
    <screenshot type="default">
      <image>https://cdn.usearctic.sh/flatpak-screenshots/screenix-editor.png</image>
    </screenshot>
    <screenshot>
      <image>https://cdn.usearctic.sh/flatpak-screenshots/screenix-export.png</image>
    </screenshot>
    <screenshot>
      <image>https://cdn.usearctic.sh/flatpak-screenshots/screenix-menu.png</image>
    </screenshot>
  </screenshots>

  <releases>
    <release version="1.0.1" date="2026-05-20"/>
    <release version="1.0.0" date="2026-05-20"/>
  </releases>

  <content_rating type="oars-1.1"/>
</component>
